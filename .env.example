# ── Telegram ─────────────────────────────────────────────────────────────
# From @BotFather when you create the bot.
TELEGRAM_BOT_TOKEN=

# A random string you invent. Telegram echoes it back on every webhook call in
# the X-Telegram-Bot-Api-Secret-Token header so we can verify the request is
# genuinely from Telegram. Generate one with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Michele's Telegram numeric user id (the "fearless leader" who gets the summary).
# She is always an admin for /team.
MICHELE_CHAT_ID=247646511

# Optional: extra Telegram user ids (comma-separated) allowed to use /team.
# Admins are also CC'd on the daily summary so they see what Michele sees.
ADMIN_CHAT_IDS=

# ── Supabase ─────────────────────────────────────────────────────────────
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Service-role key (server-side only — NEVER expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=

# ── Cron / security ──────────────────────────────────────────────────────
# Vercel automatically sends this as a Bearer token on scheduled cron calls
# when it is set as an env var. Generate with: openssl rand -hex 32
CRON_SECRET=

# Protects the one-time /api/telegram/setup endpoint. Generate with: openssl rand -hex 32
SETUP_SECRET=

# ── Config ───────────────────────────────────────────────────────────────
# Timezone offset in minutes used to compute the local "check-in date".
# UTC+8 (Philippines) = 480. Change if the team moves timezones.
TZ_OFFSET_MINUTES=480

# Public base URL of the deployment, used when registering the Telegram webhook.
# e.g. https://amplifi-capchecker.vercel.app
PUBLIC_BASE_URL=

# Optional but recommended: password for the web dashboard. When set, the
# dashboard shows a login form (and still accepts the legacy ?key=<value>
# link). Once logged in, a cookie remembers the visitor for 180 days. Leave
# empty to keep the dashboard open.
DASHBOARD_PASSWORD=

# ── Signal thresholds (all optional — see /about on the dashboard) ─────────
# Every default lives in lib/analytics.ts; set any of these to override
# without a code change. Uncomment and edit as needed.
# THRESHOLD_STRUCTURAL_LINE=5
# THRESHOLD_STRUCTURAL_DAYS=7
# THRESHOLD_MIN_HISTORY_DAYS=10
# THRESHOLD_STRAIN_AVG=3.5
# THRESHOLD_STRAIN_GAP=2
# THRESHOLD_THEME_SHARE=0.4
# THRESHOLD_THEME_MIN_COUNT=3
# THRESHOLD_RESPONSE_FLOOR=0.7
# THRESHOLD_STRAIN_ZONE=3
