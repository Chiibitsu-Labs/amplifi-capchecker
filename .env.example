# ── Telegram ─────────────────────────────────────────────────────────────
# From @BotFather when you create the bot.
TELEGRAM_BOT_TOKEN=

# A random string you invent. Telegram echoes it back on every webhook call in
# the X-Telegram-Bot-Api-Secret-Token header so we can verify the request is
# genuinely from Telegram. Generate one with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Michele's Telegram numeric user id (the "fearless leader" who gets the summary).
MICHELE_CHAT_ID=247646511

# ── Supabase ─────────────────────────────────────────────────────────────
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Service-role key (server-side only — NEVER expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=

# ── Cron / security ──────────────────────────────────────────────────────
# Vercel automatically sends this as a Bearer token on scheduled cron calls
# when it is set as an env var. Generate with: openssl rand -hex 32
CRON_SECRET=

# Protects the one-time /api/telegram/setup endpoint. Generate with: openssl rand -hex 32
SETUP_SECRET=

# ── Config ───────────────────────────────────────────────────────────────
# Timezone offset in minutes used to compute the local "check-in date".
# UTC+8 (Philippines) = 480. Change if the team moves timezones.
TZ_OFFSET_MINUTES=480

# Public base URL of the deployment, used when registering the Telegram webhook.
# e.g. https://amplifi-capchecker.vercel.app
PUBLIC_BASE_URL=
